# Public Demo Environment Variables Template (Vercel & Render Free Tiers - Neon DB)
# Copy this file to .env and configure details on Render/Vercel settings dashboards.

# Core Backend Node Settings
NODE_ENV=production
PORT=10000
APP_MODE=demo
PROVIDER_MODE=free_demo

# Neon Database Connection String (Pooled connection URL - host has -pooler)
DATABASE_URL=postgresql://neondb_owner:<neon-password>@ep-dry-term-ao0g9wds-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Neon Database Direct Connection String (Unpooled connection URL - host does NOT have -pooler, required for Prisma migrations)
DIRECT_URL=postgresql://neondb_owner:<neon-password>@ep-dry-term-ao0g9wds.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Cache & Queuing Settings (Disabled for Render free-tier in-process operation)
REDIS_ENABLED=false
REDIS_URL=

# Express Session Cookie Secret Key
SESSION_SECRET=demo_deployment_secure_key_session_store_secret_change_me_in_production

# CORS Allowed Origins (Supports comma-separated list of whitelisted domains)
CORS_ORIGIN=https://<vercel-domain>.vercel.app,http://localhost:3000

# Cookie SameSite & Security Controls
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# Local File Upload Location (Render ephemeral storage path)
UPLOAD_DIR=uploads/tickets

# Frontend Next.js Public Environment Variables
# API Server base URL for direct client-side requests (Option A) or leave blank if using Same-origin rewriting (Option B)
NEXT_PUBLIC_API_BASE_URL=https://<render-api-name>.onrender.com
NEXT_PUBLIC_API_URL=https://<render-api-name>.onrender.com

# Frontend Site Public URL (Used for generating Time Bill share links)
NEXT_PUBLIC_SITE_URL=https://<vercel-domain>.vercel.app
FRONTEND_URL=https://<vercel-domain>.vercel.app
