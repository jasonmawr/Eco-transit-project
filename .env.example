# Core Application Configuration
PORT=3001
APP_MODE=local
PROVIDER_MODE=local

# Database Configuration (Neon Pooled connection - host has -pooler)
DATABASE_URL=postgresql://neondb_owner:***@ep-dry-term-ao0g9wds-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Direct Connection Configuration (Neon Unpooled connection - host does NOT have -pooler)
DIRECT_URL=postgresql://neondb_owner:***@ep-dry-term-ao0g9wds.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Cache & Queue Configuration (Redis - Set to false if running no-Docker)
REDIS_ENABLED=false
REDIS_URL=

# Authentication (Session Store)
SESSION_SECRET=a_very_long_secure_random_session_secret_key_1234567890

# Cookie security settings (Optional override)
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Local File Upload Location
UPLOAD_DIR=uploads/tickets

# Frontend Linkage
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Optional Third-Party Provider Keys
GOOGLE_MAPS_API_KEY=
GOOGLE_VISION_API_KEY=
GOOGLE_WEATHER_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini API Key
GEMINI_API_KEY=
