# Local Development Configuration (No Docker - Neon DB)
PORT=3001
APP_MODE=local
PROVIDER_MODE=local

# Neon Database Configuration (Pooled)
DATABASE_URL=postgresql://neondb_owner:***@ep-dry-term-ao0g9wds-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Neon Database Configuration (Direct Connection)
DIRECT_URL=postgresql://neondb_owner:***@ep-dry-term-ao0g9wds.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Local Cache (Disabled locally)
REDIS_ENABLED=false
REDIS_URL=

# Authentication
SESSION_SECRET=local_development_secure_key_session_store_secret

# Cookie security settings (Optional override)
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Local File Upload Location
UPLOAD_DIR=uploads/tickets

# Frontend Linkage
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
